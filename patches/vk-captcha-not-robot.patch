+// ---- Персист TURN-кредов на диск ----
+// Кэш кредов живёт в памяти и терялся при каждом рестарте процесса, из-за чего
+// ЛЮБОЙ перезапуск (смена флагов, перезагрузка роутера, respawn) требовал заново
+// проходить капчу VK. Сохраняем креды на диск и переиспользуем, пока они живы —
+// капча нужна только когда VK их реально отвергнет.
+var credsFilePath = func() string {
+	if p := os.Getenv("VKTURN_CREDS_FILE"); p != "" {
+		return p
+	}
+	return "/etc/vkturn/creds.json"
+}()
+
+type persistedCreds struct {
+	Username   string    `json:"username"`
+	Password   string    `json:"password"`
+	ServerAddr string    `json:"server_addr"`
+	ExpiresAt  time.Time `json:"expires_at"`
+	Link       string    `json:"link"`
+}
+
+func saveCredsToDisk(c TurnCredentials) {
+	b, err := json.Marshal(persistedCreds{
+		Username: c.Username, Password: c.Password, ServerAddr: c.ServerAddr,
+		ExpiresAt: c.ExpiresAt, Link: c.Link,
+	})
+	if err != nil {
+		return
+	}
+	tmp := credsFilePath + ".tmp"
+	if err := os.WriteFile(tmp, b, 0600); err != nil {
+		return
+	}
+	if err := os.Rename(tmp, credsFilePath); err != nil {
+		_ = os.Remove(tmp)
+		return
+	}
+	log.Printf("[VK Auth] Креды сохранены на диск (%s)", credsFilePath)
+}
+
+func loadCredsFromDisk(link string) (TurnCredentials, bool) {
+	b, err := os.ReadFile(credsFilePath)
+	if err != nil {
+		return TurnCredentials{}, false
+	}
+	var p persistedCreds
+	if err := json.Unmarshal(b, &p); err != nil {
+		return TurnCredentials{}, false
+	}
+	if p.Link != link || p.Username == "" || time.Now().After(p.ExpiresAt) {
+		return TurnCredentials{}, false
+	}
+	return TurnCredentials{
+		Username: p.Username, Password: p.Password, ServerAddr: p.ServerAddr,
+		ExpiresAt: p.ExpiresAt, Link: p.Link,
+	}, true
+}
+
+func dropCredsFromDisk() { _ = os.Remove(credsFilePath) }
+
 func getCacheID(streamID int) int {
 	return streamID / streamsPerCache
 }
