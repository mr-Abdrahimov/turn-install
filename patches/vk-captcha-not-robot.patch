+// captchaTLSConfig возвращает TLS-конфиг с самоподписанным сертификатом (генерируется 1 раз).
+func captchaTLSConfig() *tls.Config {
+	captchaTLSOnce.Do(func() {
+		cert, err := selfsign.GenerateSelfSigned()
+		if err != nil {
+			log.Printf("[Captcha] self-signed cert error: %v", err)
+			return
+		}
+		captchaTLSCfg = &tls.Config{Certificates: []tls.Certificate{cert}}
+	})
+	return captchaTLSCfg
