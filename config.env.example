# ============================================================================
#  VK-TURN — единый файл настроек. Скопируй в config.env и заполни:
#      cp config.env.example config.env && nano config.env
#  Оба установщика (install-server.sh, install-openwrt.sh) читают config.env
#  автоматически. Значения можно переопределить флагами командной строки.
# ============================================================================

# ---- ОБЩЕЕ (нужно и серверу, и роутеру) ------------------------------------

# Публичный IP твоего VPS (куда TURN-релеи VK шлют трафик). Пример: 2.27.12.78
SERVER_IP=""

# Публичный порт vk-turn server (TCP+UDP). Наружу открыт только он.
PROXY_PORT="56000"

# Репозиторий с релизами ядра (обычно не меняем).
CORE_REPO="cacggghp/vk-turn-proxy"


# ---- СЕРВЕР (install-server.sh) --------------------------------------------

# Локальный UDP-порт AmneziaWG на сервере (наружу НЕ открывается).
AWG_PORT="51820"

# Имя первого клиентского пира (файл /root/awg-client-<имя>.conf).
CLIENT_NAME="router"


# ---- РОУТЕР / КЛИЕНТ (install-openwrt.sh) ----------------------------------

# Ссылка на ДЕЙСТВУЮЩИЙ звонок VK — источник TURN-кредов.
# Создать: vk.com/Звонки → «Создать звонок» → «Копировать ссылку». Звонок можно не начинать.
# Формат: https://vk.ru/call/join/XXXXXXXXXXXXXXXXXXX
VK_LINK=""

# Потоки к TURN. ЗАМЕРЕНО: полоса режется на КАЖДЫЙ поток (~6 КБ/с), суммируется,
# но насыщается: 1 поток=8 КБ/с, 8=49, 16=70, 32=67 (прироста уже нет).
# 16 — оптимум. Потолок технологии ~70 КБ/с (~0.5 Мбит/с) — это ограничение
# TURN-релеев VK, а не нашей сборки.
THREADS="16"

# UDP-режим к TURN: 1 = включить (если TCP-хендшейк не проходит), 0 = TCP.
USE_UDP="0"

# ---- WATCHDOG (авто-восстановление туннеля, напр. после reload zeroblock) ----

# Имя AmneziaWG-интерфейса туннеля на роутере (как в UCI network.<IFACE>).
AWG_IFACE="OrangeVPN"

# AWG-адрес сервера (из awg-client-*.conf, поле Address сервера — обычно 10.8.1.1).
# Watchdog пингует его через туннель для проверки живости.
AWG_PEER_IP="10.8.1.1"
